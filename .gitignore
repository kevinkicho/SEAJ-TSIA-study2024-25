# Source materials not redistributed here (copyright + size)
*.pdf
*.jpg
*.jpeg
*.png
*.gif
*.webp

# But DO commit screenshots / docs images that are part of the repo's documentation
!docs/img/*.png
!docs/img/*.jpg
!docs/img/*.jpeg

# OS / system
desktop.ini
.DS_Store
Thumbs.db

# Misc binaries / unnamed files
*.ini

# Extensionless research-note files that slipped in
taiwan mask corp annual report 2024 030926
vis company 030926

# Python build artifacts
__pycache__/
*.pyc
.pytest_cache/

# JSON-extraction backups (created automatically by apply_corrections / patch_blockers)
*.pre-correction-bak
*.pre-blocker-fix-bak
*.pre-triage-bak
*.pre-extension-bak
*.json.bak

# Intermediate pipeline state — regenerated by re-running scripts/
graphify-financial/vision_batches/
graphify-financial/balance_sheet_batches/
graphify-financial/bulk_page_candidates.json
graphify-financial/bulk_rasterize_summary.json
graphify-financial/page_candidates.json
graphify-financial/rasterize_summary.json
graphify-financial/audit_findings.json

# Per-PDF rasterized PNG cache (large; regenerable from PDFs via bulk_rasterize.py)
graphify-financial/*/pages/

# Marker pipeline (superseded; outputs not committed)
graphify-marker/
graphify-out/cache/

# Logs
*.log
nohup.out
