      "_corrections_applied": [
        {
          "rule_targeted": "GP - OpEx = OpInc",
          "year": "2023",
          "issue": "Two issues: (1) Operating expenses stored as a negative number (-23,855,503), so validator computes GP - OpEx = GP + |OpEx| which inflates the result. Should be positive magnitude. (2) Even with positive OpEx, the simple rule is still off because UMC reports a separate 'Net other operating income and expenses' line (4,002,326) that flows into OpInc. Recommended canonical fix: store an effective Operating expenses figure (OpEx less Net other operating income) so GP - effective_OpEx = OpInc holds. Also typo in 2023 Operating income: stored 57,886,661, PNG shows 57,890,661."
        },
        {
          "rule_targeted": "GP - OpEx = OpInc",
          "year": "2024",
          "issue": "Same as 2023: OpEx stored negative, missing Net other operating income offset."
        }
