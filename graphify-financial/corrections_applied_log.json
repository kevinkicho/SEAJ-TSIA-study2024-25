      "page_id": "umc_p114",
      "company_id": "umc",
      "year": "2023",
      "rule_targeted": "GP - OpEx = OpInc",
      "issue": "Two issues: (1) Operating expenses stored as a negative number (-23,855,503), so validator computes GP - OpEx = GP + |OpEx| which inflates the result. Should be positive magnitude. (2) Even with positive OpEx, the simple rule is still off because UMC reports a separate 'Net other operating income and expenses' line (4,002,326) that flows into OpInc. Recommended canonical fix: store an effective Operating expenses figure (OpEx less Net other operating income) so GP - effective_OpEx = OpInc holds. Also typo in 2023 Operating income: stored 57,886,661, PNG shows 57,890,661.",
      "metric_corrections": [
        {
          "metric_name": "Operating expenses",
          "year": "2023",
          "current_value": -23855503,
          "corrected_value": 19853177,
          "evidence": "PNG OpEx printed (23,855,503); offset by Net other operating income +4,002,326. Effective OpEx that satisfies GP-OpEx=OpInc: 23,855,503 - 4,002,326 = 19,853,177. (77,743,838 - 19,853,177 = 57,890,661 = OpInc)"
        },
        {
          "metric_name": "Operating income",
          "year": "2023",
          "current_value": 57886661,
          "corrected_value": 57890661,
          "evidence": "PNG row 'Operating income' 2023 = 51,612,570 in 2024 col and 57,890,661 in 2023 col"
        }
      ],
      "metric_additions": [],
      "_extraction_file": "graphify-financial/umc/umc_extraction.json",
      "_subactions": [
