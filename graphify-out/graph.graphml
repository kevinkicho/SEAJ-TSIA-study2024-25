    <node id="save_sales_approach">
      <data key="d0">S.A.V.E. Sales Approach</data>
      <data key="d6">concept</data>
      <data key="d7">Ajinomoto's customer engagement methodology: Solution-Access-Value-Entanglement. Close collaboration with customers from product development stage onward after ascertaining their true needs; ABF is used as a certified material by major semiconductor makers.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">89</data>
      <data key="d5">s.a.v.e. sales approach</data>
    </node>
    <node id="asset_light_model">
      <data key="d0">Asset-Light Outsourced Coating/Logistics Model</data>
      <data key="d6">concept</data>
      <data key="d7">Ajinomoto's business model: in-house varnish production and R&amp;D, but outsources coating (to film converters) and low-temperature distribution (to logistics companies). Enables scale-up without heavy capex.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">90</data>
      <data key="d5">asset-light outsourced coating/logistics model</data>
    </node>
    <node id="logic_ic_market">
      <data key="d0">Logic IC Product Market</data>
      <data key="d6">market</data>
      <data key="d7">Projected growth index (2012=100): 2012=100, 2013=105, 2014=112, 2015=111, 2016=112, 2017=125, 2018=134, 2019=139. Long-term growth trend driven by server CPUs/GPUs and ASICs/FPGAs for network applications (Ajinomoto Fine-Techno forecast).</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">91</data>
      <data key="d5">logic ic product market</data>
    </node>
    <node id="data_center_server_market">
      <data key="d0">Data Center Server Market</data>
      <data key="d6">market</data>
      <data key="d7">Forecast 2017-2022 CAGR: 7.2% (millions of units). Source: Ajinomoto Fine-Techno. Drives ABF demand via server CPU/GPU packaging.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">92</data>
      <data key="d5">data center server market</data>
    </node>
    <node id="abf_sales_history">
      <data key="d0">ABF Sales History (Rebased 2000=100)</data>
      <data key="d6">market</data>
      <data key="d7">Phase 1 (2000-2007) Growth: rapid rise to ~500-600 driven by Internet popularization and PC demand. Phase 2 (2008-2012) Temporary Lull: stagnation due to smartphones/tablets, PC market plateau, global financial crisis. Phase 3 (2013+) New Growth: recovery to ~700-800 via expansion into non-PC applications (servers, telecommunications).</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">93</data>
      <data key="d5">abf sales history (rebased 2000=100)</data>
    </node>
    <node id="tech_param_line_space">
      <data key="d0">ABF Line/Space = 10/10 um</data>
      <data key="d6">technology_parameter</data>
      <data key="d7">ABF enables fine copper pattern at line/space of 10 micrometers / 10 micrometers, allowing smaller and higher-density interconnects on build-up substrates.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">94</data>
      <data key="d5">abf line/space = 10/10 um</data>
    </node>
    <node id="tech_param_low_df">
      <data key="d0">Low Dielectric Tangent (Low Df)</data>
      <data key="d6">technology_parameter</data>
      <data key="d7">Key dielectric property for high-frequency (5G, networking) ABF variants; enables low signal loss at high frequencies. Ajinomoto launched ABF variants achieving low Df.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">95</data>
      <data key="d5">low dielectric tangent (low df)</data>
    </node>
    <node id="tech_param_heat_resistance">
      <data key="d0">High Heat Resistance &amp; Temperature Cycle Reliability</data>
      <data key="d6">technology_parameter</data>
      <data key="d7">ABF is highly heat resistant and mechanically strong when cured, with high temperature cycle reliability — required for semiconductor packaging where substrate experiences repeated thermal excursions.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">96</data>
      <data key="d5">high heat resistance &amp; temperature cycle reliability</data>
    </node>
    <node id="tech_param_flame_retardant">
      <data key="d0">Flame Retardancy</data>
      <data key="d6">technology_parameter</data>
      <data key="d7">ABF is flame retardant when cured, meeting semiconductor packaging safety requirements.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">97</data>
      <data key="d5">flame retardancy</data>
    </node>
    <node id="tech_param_insulation_reliability">
      <data key="d0">High Insulation Reliability</data>
      <data key="d6">technology_parameter</data>
      <data key="d7">ABF provides high insulation reliability between copper layers in build-up substrate, preventing leakage between dense interconnect traces.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">98</data>
      <data key="d5">high insulation reliability</data>
    </node>
    <node id="tech_param_uniform_thickness">
      <data key="d0">Uniform Insulation Layer Thickness</data>
      <data key="d6">technology_parameter</data>
      <data key="d7">Film form factor of ABF enables easy formation of insulation layers with uniform thickness, overcoming poor surface planarity and residual air bubbles of earlier liquid interlayer insulator inks.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">99</data>
      <data key="d5">uniform insulation layer thickness</data>
    </node>
