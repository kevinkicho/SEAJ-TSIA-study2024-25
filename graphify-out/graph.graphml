    <node id="pcie_standard">
      <data key="d0">PCIe (PCI Express) / PCI-SIG</data>
      <data key="d6">technology_standard</data>
      <data key="d10">{"role": "physical layer / base protocol for CXL"}</data>
      <data key="d9">CXL specification 4.0</data>
