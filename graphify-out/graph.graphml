      <data key="d0">Ajinomoto Build-up Film (ABF)</data>
      <data key="d6">product</data>
      <data key="d7">World's first film produced from liquid resin; interlayer insulating material for semiconductor packaging launched in 1999. Key attributes: easy to form uniform-thickness insulation layers, highly heat resistant, flame retardant, mechanically strong when cured, enables copper microcircuit fabrication via plating (L/S=10/10 um), high insulation and temperature cycle reliability. Manufactured through low-waste environment-friendly process. Supports build-up method of multilayer PCB manufacturing with laser vias.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">42</data>
      <data key="d5">ajinomoto build-up film (abf)</data>
    </node>
    <node id="abf_low_dk_df_variant">
      <data key="d0">ABF Low Dielectric Tangent (High-Frequency) Variant</data>
      <data key="d6">product</data>
      <data key="d7">ABF variant launched to market to achieve low dielectric tangent (low Df) for high-frequency applications such as 5G communications and networking. Developed for expanding server and communication applications.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">43</data>
      <data key="d5">abf low dielectric tangent (high-frequency) variant</data>
    </node>
    <node id="abf_fine_line_variant">
      <data key="d0">ABF Fine-Line (L/S=10/10 um) Variant</data>
      <data key="d6">product</data>
      <data key="d7">ABF grade enabling fine copper patterning at line/space = 10/10 micrometers via semi-additive plating process; used in advanced high-density build-up substrates.</data>
      <data key="d8">0.9</data>
      <data key="d9">INFERRED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">44</data>
      <data key="d5">abf fine-line (l/s=10/10 um) variant</data>
    </node>
    <node id="msg_monosodium_glutamate">
      <data key="d0">Monosodium Glutamate (MSG)</data>
      <data key="d6">product</data>
      <data key="d7">Seasoning product; synthesis R&amp;D in the 1950s-1960s generated intermediates (glutamate from soybeans/wheat, chlorinated paraffin from caustic soda/chlorine) that were repurposed into the epoxy resin curing agent business and ultimately ABF.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">45</data>
      <data key="d5">monosodium glutamate (msg)</data>
    </node>
