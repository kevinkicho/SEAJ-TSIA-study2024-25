      <data key="d10">{"latest_revision": "4.0 (November 2025)", "release_timeline": {"1.0": "March 2019", "1.1": "September 2019", "2.0": "November 2020 (memory pooling, CXL switch)", "3.0": "August 2022 (multi-level switching, memory sharing, 64 GT/s)", "3.1": "November 2023 (CXL Fabric, port-based routing)", "3.2": "December 2024 (security, compliance)", "4.0": "November 2025 (bundled ports, 128 GT/s)"}, "use_cases": ["heterogeneous compute with accelerators", "memory pooling", "coherent memory sharing", "memory t</data>
      <data key="d9">CXL-Specification_rev4p0_ver1p0.pdf; CXL_4.0-Webinar; CXL_Q2-2025-Webinar</data>
      <data key="d13">1.0</data>
      <data key="d4">15</data>
      <data key="d5">cxl (compute express link) specification</data>
      <data key="d7">A dynamic multi-protocol, low-latency, high-bandwidth CPU-to-device interconnect standard designed to support accelerators and memory devices. Uses dynamic protocol muxing of I/O, coherency, and memory access protocols over PCIe electricals. Maintained by the Compute Express Link Consortium (280+ member companies).</data>
      <data key="d8">1.0</data>
    </node>
