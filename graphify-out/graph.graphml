    <node id="abf_varnish">
      <data key="d0">ABF Varnish</data>
      <data key="d6">product</data>
      <data key="d7">Liquid epoxy-based resin varnish produced by Ajinomoto; precursor material that film converters coat onto carrier film to produce finished ABF sheets. Upstream stage of ABF value chain.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">56</data>
      <data key="d5">abf varnish</data>
    </node>
    <node id="semiconductor_package_substrate">
      <data key="d0">Semiconductor Package Substrate (Build-up Substrate)</data>
      <data key="d6">product</data>
      <data key="d7">Multilayer printed circuit board (build-up substrate) used as interposer between semiconductor die and main PCB. Manufactured using build-up method: core material + sequentially laminated build-up layers (ABF) with laser-drilled vias and copper interconnects. Used in flip-chip plastic packages.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">57</data>
      <data key="d5">semiconductor package substrate (build-up substrate)</data>
    </node>
    <node id="flip_chip_package">
      <data key="d0">Flip-Chip Plastic Package</data>
      <data key="d6">technology</data>
      <data key="d7">Semiconductor packaging technology that replaced wire bonding + ceramic packages in latter half of 1990s. Uses plastic build-up substrate with flip-chip interconnect; enables higher-density interconnects, higher-speed signal transmission, and lighter-weight substrates. ABF enabled mass proliferation of this technology in PCs.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">58</data>
      <data key="d5">flip-chip plastic package</data>
    </node>
    <node id="build_up_pcb_method">
      <data key="d0">Build-up PCB Manufacturing Method</data>
      <data key="d6">technology</data>
      <data key="d7">Method of manufacturing multilayer PCBs by sequentially adding laminate layers to a core, laser-drilling vias, fabricating copper interconnects via plating. Enables fine copper patterning (L/S=10/10 um) and, in turn, smaller devices.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">59</data>
      <data key="d5">build-up pcb manufacturing method</data>
    </node>
    <node id="laser_via_drilling">
      <data key="d0">Laser Via Drilling</data>
      <data key="d6">technology</data>
      <data key="d7">Process used in build-up method to create microvias between build-up layers of ABF-based substrates.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">60</data>
      <data key="d5">laser via drilling</data>
    </node>
    <node id="semi_additive_plating">
      <data key="d0">Semi-Additive Copper Plating</data>
      <data key="d6">technology</data>
      <data key="d7">Copper interconnect fabrication method enabled by roughing ABF surface with oxidant, then applying copper plating. Allows fine-line (L/S=10/10 um) copper patterning on ABF insulating layer.</data>
      <data key="d8">0.9</data>
      <data key="d9">INFERRED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">61</data>
      <data key="d5">semi-additive copper plating</data>
    </node>
    <node id="app_server_cpu">
      <data key="d0">Server CPU Application</data>
      <data key="d6">application</data>
      <data key="d7">Server CPUs and GPUs for data center / cloud computing workloads. Identified as key growth driver for ABF from 2013 onward with cloud services market expansion; 2017-2022 CAGR of 7.2% forecast for data center server units.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">62</data>
      <data key="d5">server cpu application</data>
    </node>
    <node id="app_pc_cpu">
      <data key="d0">PC CPU Application</data>
      <data key="d6">application</data>
      <data key="d7">Desktop/laptop CPU packaging; historical anchor application for ABF from 1999 launch through 2007 growth period. Market became stagnant after 2008 with smartphone/tablet rise.</data>
      <data key="d8">1.0</data>
      <data key="d9">EXTRACTED</data>
      <data key="d2">AJINOMOTO FINE INC ABF-presentation.pdf</data>
      <data key="d1">paper</data>
      <data key="d4">63</data>
      <data key="d5">pc cpu application</data>
    </node>
